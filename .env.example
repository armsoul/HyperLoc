# HyperLoc - Arquivo de Configuração de Exemplo
# Copie este arquivo para .env e preencha com suas configurações

# ============================================================================
# AMBIENTE
# ============================================================================
NODE_ENV=development
PORT=5000

# ============================================================================
# FRONTEND
# ============================================================================
VITE_API_URL=http://localhost:5000
VITE_APP_TITLE=HyperLoc

# ============================================================================
# BANCO DE DADOS
# ============================================================================
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=root
DB_NAME=hyperloc

# ============================================================================
# AUTENTICAÇÃO JWT
# ============================================================================
JWT_SECRET=sua_chave_secreta_super_segura_aqui_min_32_caracteres
JWT_EXPIRES_IN=24h

# ============================================================================
# APLICAÇÃO
# ============================================================================
APP_NAME=HyperLoc
APP_VERSION=1.0.0
APP_URL=http://localhost:5000

# ============================================================================
# LOGS
# ============================================================================
LOG_LEVEL=debug

# ============================================================================
# CORS
# ============================================================================
CORS_ORIGIN=http://localhost:5173,http://localhost:3000

# ============================================================================
# EMAIL (Opcional - para notificações futuras)
# ============================================================================
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=seu-email@gmail.com
# SMTP_PASSWORD=sua-senha-app
# SMTP_FROM=noreply@hyperloc.com

# ============================================================================
# STORAGE (Opcional - para uploads de arquivos)
# ============================================================================
# S3_BUCKET=hyperloc-uploads
# S3_REGION=us-east-1
# S3_ACCESS_KEY=sua-chave-acesso
# S3_SECRET_KEY=sua-chave-secreta

# ============================================================================
# PAGAMENTO (Opcional - para integração com gateway)
# ============================================================================
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_PUBLISHABLE_KEY=pk_test_...
